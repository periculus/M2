{
  "name": "jupyterlab-m2-heartbeat",
  "version": "0.1.0",
  "description": "A JupyterLab extension that shows M2 kernel heartbeat status",
  "keywords": [
    "jupyter",
    "jupyterlab",
    "jupyterlab-extension",
    "macaulay2"
  ],
  "homepage": "https://github.com/macaulay2/m2-jupyter-kernel",
  "bugs": {
    "url": "https://github.com/macaulay2/m2-jupyter-kernel/issues"
  },
  "license": "MIT",
  "author": "M2 Jupyter Kernel Contributors",
  "files": [
    "lib/**/*.{d.ts,eot,gif,html,jpg,js,js.map,json,png,svg,woff2,ttf}",
    "style/**/*.{css,eot,gif,html,jpg,json,png,svg,woff2,ttf}"
  ],
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "style": "style/index.css",
  "repository": {
    "type": "git",
    "url": "https://github.com/macaulay2/m2-jupyter-kernel.git"
  },
  "scripts": {
    "build": "jlpm run build:lib && jlpm run build:labextension:dev",
    "build:prod": "jlpm run clean && jlpm run build:lib && jlpm run build:labextension",
    "build:labextension": "jupyter labextension build .",
    "build:labextension:dev": "jupyter labextension build --development True .",
    "build:lib": "tsc",
    "clean": "jlpm run clean:lib",
    "clean:lib": "rimraf lib tsconfig.tsbuildinfo",
    "clean:labextension": "rimraf jupyterlab-m2-heartbeat/labextension",
    "clean:all": "jlpm run clean:lib && jlpm run clean:labextension",
    "watch": "run-p watch:src watch:labextension",
    "watch:src": "tsc -w",
    "watch:labextension": "jupyter labextension watch ."
  },
  "dependencies": {
    "@jupyterlab/application": "^3.0.0",
    "@jupyterlab/apputils": "^3.0.0",
    "@jupyterlab/notebook": "^3.0.0",
    "@jupyterlab/services": "^6.0.0",
    "@jupyterlab/statusbar": "^3.0.0",
    "@lumino/widgets": "^1.19.0"
  },
  "devDependencies": {
    "@jupyterlab/builder": "^3.1.0",
    "@typescript-eslint/eslint-plugin": "^4.8.1",
    "@typescript-eslint/parser": "^4.8.1",
    "eslint": "^7.14.0",
    "eslint-config-prettier": "^6.15.0",
    "eslint-plugin-prettier": "^3.1.4",
    "npm-run-all": "^4.1.5",
    "prettier": "^2.1.1",
    "rimraf": "^3.0.2",
    "typescript": "~4.1.3"
  },
  "jupyterlab": {
    "extension": true,
    "outputDir": "jupyterlab-m2-heartbeat/labextension"
  }
}